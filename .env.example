# HTTP 服务
GO_AGENT_PORT=8081
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=60s
HTTP_WRITE_TIMEOUT=5m
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

# PostgreSQL；这里只放安全示例，不能提交真实用户名或密码。
POSTGRESQL_DSN=postgres://user:password@localhost:5432/kenagent?sslmode=disable
POSTGRESQL_MAX_OPEN_CONNS=10
POSTGRESQL_MAX_IDLE_CONNS=5
POSTGRESQL_CONN_MAX_LIFETIME=30m
POSTGRESQL_CONN_MAX_IDLE_TIME=5m

# S3/RustFS。若本地没有对象存储，把 RUSTFS_ENABLED 改为 false。
RUSTFS_ENABLED=true
RUSTFS_BUCKET_NAME=
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_PATH_STYLE=true

# RUSTFS_ENABLED=false 时使用的本地目录。
LOCAL_STORAGE_DIR=.data/storage

# OpenAI-compatible Embeddings API。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT=60s

# 知识文档上传策略。
KNOWLEDGE_DOCUMENT_ALLOWED_EXTENSIONS=pdf,doc,docx,txt,md,markdown,html,htm
KNOWLEDGE_DOCUMENT_MAX_SIZE=50MB

# 结构化日志。
LOG_LEVEL=info
LOG_FORMAT=json
