# Developer identity (local only)
.developer

# Current task pointer (each dev works on different task)
.current-task

# Session/window scoped runtime state
.runtime/

# Ralph Loop state file
.ralph-state.json

# Agent runtime files
.agents/
.agent-log
.session-id

# Task directory runtime files
.plan-log

# Atomic update temp files
*.tmp

# Update backup directories
.backup-*

# Conflict resolution temp files
*.new

# Python cache
**/__pycache__/
**/*.pyc

# Local Maven cache and machine-specific settings
workspace/maven-repository/
workspace/maven-settings-local.xml

# Local Go cache
workspace/go-build-cache/
workspace/go-mod-cache/
workspace/go-telemetry/
